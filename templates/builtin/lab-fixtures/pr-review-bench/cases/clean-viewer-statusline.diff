+// (#691) Coarse relative-time. Past only (recent runs are completed).
+// (#1103) Reference is explicit: playback cards measure vs the scrubber `state.t`;
+// the live idle headline passes `Date.now()` so "last run" is real wall-clock
+// elapsed, not time-since-newest-record (state.t=tMax in live → a stuck "just now").
+const relAgoFrom=(ref,t)=>{const d=ref-t;if(d<0)return"";const s=Math.floor(d/1000);
+  if(s<60)return s<5?"just now":s+"s ago";const m=Math.floor(s/60);if(m<60)return m+"m ago";
   const h=Math.floor(m/60);if(h<24)return h+"h ago";return Math.floor(h/24)+"d ago";};
+const relAgo=t=>relAgoFrom(state.t,t);
 // (#691) "<clock> · <rel ago>", dropping the separator when rel is empty (a
 // running card scrubbed to before its start in playback yields no relative).
 const stamp=(verb,t)=>{const r=relAgo(t);return `${verb} ${clk(t)}${r?' · '+r:''}`;};
