 const clkhm=t=>new Date(t).toLocaleTimeString([],{hour:"2-digit",minute:"2-digit",hour12:false});
 const lday=t=>new Date(t).toLocaleDateString();
 const ldt=t=>new Date(t).toLocaleString([],{hour12:false});
