   const last=closes.length?Math.max(...closes.map(r=>T(r.ts))):null;
-  const recent=last!=null&&(state.t-last)>=0&&(state.t-last)<=IDLE_LAST_RUN_RECENT_MS;
-  const ago=recent?relAgo(last):'';
-  return `● fleet ready · ${n} machine${n===1?'':'s'}${ago?` · last run ${ago}`:''}`;
+  // (#1103) "last run" measured from real wall-clock now, NOT state.t (=tMax, the
+  // newest record): an idle fleet's playhead sits on its last record, so the old
+  // reference made every idle headline read "just now". Machine count here is
+  // PRESENCE (LIVE_MACHINES) → labeled "online", and kept off the records line so
+  // record volume isn't conflated with who's merely up. Returns HTML (colored
+  // dot); renderMeta inserts it without esc() — inputs are counts + safe strings.
+  const now=Date.now();
