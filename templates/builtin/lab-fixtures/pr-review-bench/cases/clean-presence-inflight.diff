@@ -1795,7 +1812,15 @@ <h3>tier decision: ${esc(r.handle)}</h3>
   const sessions=Object.keys(starts).map(sid=>{
     const st=starts[sid], cp=dispatchEnd(sid), close=sessionCloseEdge(sid);
     const started=T(st.ts)<=state.t, ended=close&&T(close.ts)<=state.t;
-    const status=!started?"backlog":(ended?(dispatchErrored(cp)?"errored":"complete"):"active");
+    // (#857) "in flight" routes through the shared sessionRunning() (live=presence,
