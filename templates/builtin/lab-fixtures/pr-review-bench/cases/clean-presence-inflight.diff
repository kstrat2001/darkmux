 }
 function machActive(m){
-  const v=visible();
-  const starts=v.filter(r=>uidOf(r)===m&&r.action==="dispatch.start").map(r=>r.session_id);
-  // (#720) A run is done when it reached EITHER terminal — without counting
-  // `dispatch.error`, a killed run keeps its machine "active" forever.
-  // (#856) A SIGKILL is uncatchable, so the Drop-based bookend guard (#717)
-  // can't emit `dispatch.error` on a hard kill — the reconciler's `session.end`
-  // (#647) is the compensating close-edge. Count it too, else a hard-killed
-  // dispatch shows "in flight" forever even after the session is gone.
-  const dones=v.filter(r=>uidOf(r)===m&&(r.action==="dispatch.complete"||r.action==="dispatch.error"||r.action==="session.end")).map(r=>r.session_id);
-  return starts.some(s=>!dones.includes(s));
+  // (#857) A machine is in flight iff one of its started sessions is still
+  // running — routed through the shared sessionRunning() (live = presence,
+  // playback = close-edge at the playhead). A hard-killed/orphaned dispatch no
+  // longer pins the machine "active" forever: it ages out of presence in live
+  // mode, and is bracketed by its close-edge (incl. session.end) in playback.
+  return visible().some(r=>uidOf(r)===m&&r.action==="dispatch.start"&&sessionRunning(r.session_id));
 }
 // (#638 Slice 3) Is machine `m` PRESENT at the scrubber time `state.t`?
 //   true  = present · false = absent (offline) · null = unknown (no evidence)
@@ -1059,11 +1071,16 @@ <h3><span>event log · <span id="logscope">fleet</span></span>
   const lanes=ms.map(m=>{
     const bars=sessionsOn(m).map(sid=>{
