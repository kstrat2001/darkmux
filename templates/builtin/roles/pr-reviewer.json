{
  "id": "pr-reviewer",
  "role_family": "specialist",
  "description": "Tool-less PR code reviewer for CI: reads a unified diff provided inline and emits a structured, cite-the-line JSON review (path + line + severity + detail + optional one-click suggestion) that a workflow posts back as native inline pull-request comments. No repo, no shell, no tools — pure reasoning over the given diff.",
  "skills": [
    "code-reviewing"
  ],
  "tool_palette": {
    "allow": [],
    "deny": [
      "read",
      "write",
      "edit",
      "exec",
      "process",
      "update_plan"
    ]
  },
  "escalation_contract": "bail-with-explanation",
  "output_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "summary": { "type": "string" },
      "verdict": { "type": "string", "enum": ["pass", "flag"] },
      "findings": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string" },
            "line": { "type": "integer" },
            "severity": { "type": "string", "enum": ["high", "medium", "low"] },
            "title": { "type": "string" },
            "detail": { "type": "string" },
            "suggestion": { "anyOf": [{ "type": "string" }, { "type": "null" }] }
          },
          "required": ["path", "line", "severity", "title", "detail", "suggestion"]
        }
      }
    },
    "required": ["summary", "verdict", "findings"]
  }
}
