# Rust build artifacts
target/
**/*.rs.bk
Cargo.lock.bak

# darkmux runtime state (project-local + defense-in-depth)
.darkmux/
runs/
sandboxes/
*.trajectory.jsonl
qa-reply.json
qa-reply.err
cpu-samples.txt

# Run-artifact dirs — keep them out of committed fixtures (a committed one
# trips `lab doctor`'s cleanliness check + the workspace test). Mirrors the
# canonical RUN_ARTIFACT_DIRS the lab clone prunes + the hash excludes.
__pycache__/
*.pyc
coverage/
.coverage
.darkmux-runtime/
.darkmux-agent/

# dotenv files (local secrets)
.env
.env.local
.env.*.local

# OS / editor noise
.DS_Store
.idea/
.vscode/
.claude/

# Viewer e2e (Playwright) — local artifacts
tests/e2e/node_modules/
tests/e2e/.served/
tests/e2e/test-results/
tests/e2e/playwright-report/
target-review/
