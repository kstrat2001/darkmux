{
  "schema_version": "1.2",
  "machine_id": "my-machine",
  "orchestrator": "",
  "lms_bin": "lms",
  "lmstudio_url": "http://localhost:1234",
  "redis": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 6379,
    "stream": "darkmux:flow",
    "maxlen": 10000
  },
  "audit": {
    "enabled": false,
    "dir": "~/.darkmux/audit"
  },
  "runtime": {
    "inactivity_timeout_seconds": 600,
    "model_load_timeout_seconds": 600,
    "strict_selection": false,
    "check_updates": true,
    "daemon_auth_enabled": false,
    "injected_context_fraction": 0.15
  },
  "fleet": {
    "mode": "standalone"
  },
  "remote": {
    "max_tokens_per_execution": 500000
  }
}
